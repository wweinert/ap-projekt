<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8" />
    <style>
        body {
            font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0 40px;
            color: #333;
        }

        header {
            text-align: center;
            padding: 20px 0;
            border-bottom: 2px solid #ccc;
        }

        header h1 {
            margin: 0;
            font-size: 28px;
            color: #ccc;
        }

        .section {
            margin-top: 30px;
        }

        .section h2 {
            font-size: 20px;
            margin-bottom: 10px;
            color: #ccc;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
            vertical-align: top;
        }

        th {
            background-color: #f2f2f2;
            font-weight: 600;
            width: 30%;
        }

        tr:nth-child(even) {
            background-color: #fafafa;
        }

        .image-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            margin-top: 10px;
        }

        .image-item {
            width: 180px;
        }

        .image-item img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border: 1px solid #ddd;
            border-radius: 4px;
            display: block;
            background: #fafafa;
        }

        .image-caption {
            margin-top: 6px;
            font-size: 12px;
            color: #666;
            text-align: center;
        }

        .no-images {
            padding: 12px;
            border: 1px solid #ddd;
            background-color: #fafafa;
        }

        footer {
            position: fixed;
            bottom: 20px;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 12px;
            color: #777;
        }
    </style>
</head>

<body>
    <header>
        <h1>Prüfbericht</h1>
    </header>

    <div class="section">
        <h2>Berichtsdetails</h2>
        <table>
            <tr>
                <th>Titel</th>
                <td><%= report.title %></td>
            </tr>
            <tr>
                <th>Beschreibung</th>
                <td><%= report.description || "Keine Beschreibung" %></td>
            </tr>
            <tr>
                <th>Status</th>
                <td><%= report.status === "DEFECT" ? "Defekt" : "OK" %></td>
            </tr>
            <tr>
                <th>Lieferant</th>
                <td><%= supplier.title %></td>
            </tr>
            <tr>
                <th>Erstellt von</th>
                <td><%= report.createdByEmail || "Keine Angabe" %></td>
            </tr>
            <tr>
                <th>Erstellt am</th>
                <td><%= report.createdAt ? new Date(report.createdAt).toLocaleString("de-DE") : "" %></td>
            </tr>
        </table>
    </div>

    <div class="section">
        <h2>Bildnachweise</h2>

        <% if (report.images && Array.isArray(report.images) && report.images.length) { %>
            <div class="image-grid">
                <% report.images.forEach(function (imgPath, idx) { 
                    const fullSrc = imgPath.startsWith("http")
                        ? imgPath
                        : baseUrl.replace(/\/$/, "") + imgPath;
                %>
                    <div class="image-item">
                        <img src="<%= fullSrc %>" alt="Bildnachweis <%= idx + 1 %>" />
                        <div class="image-caption">Bild <%= idx + 1 %></div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="no-images">Keine Bildnachweise vorhanden.</div>
        <% } %>
    </div>

    <footer>
        Erstellt am <%= new Date().toLocaleString("de-DE") %>
    </footer>
</body>

</html>